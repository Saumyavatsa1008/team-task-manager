rules_version = '2';

// All client access is denied. The Express API uses the firebase-admin SDK
// (which bypasses these rules) and is the single source of truth for
// validation and role-based access control. This file exists as a
// defense-in-depth measure: if the web SDK keys are leaked, no client
// can read or write Firestore directly.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
