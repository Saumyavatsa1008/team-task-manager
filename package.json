{
  "name": "team-task-manager",
  "private": true,
  "version": "1.0.0",
  "description": "Full-stack Team Task Manager — React + Express + Firebase Auth + Firestore",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "build": "npm --workspace apps/api run build && npm --workspace apps/web run build",
    "lint": "npm --workspaces run lint --if-present",
    "typecheck": "npm --workspaces run typecheck --if-present",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  },
  "engines": {
    "node": ">=20"
  }
}
