# =========================================================
#  Team Task Manager — root example env (copy values into
#  apps/api/.env and apps/web/.env respectively)
# =========================================================

# ---------- API (apps/api/.env) ----------
NODE_ENV=development
PORT=4000

# CORS origin allowlist for the web client
WEB_ORIGIN=http://localhost:5173

# Firebase project ID (same as the console)
FIREBASE_PROJECT_ID=team-task-management-system

# ONE of the following two service-account options is required:
#   - For local dev (recommended): drop the JSON file at
#       apps/api/serviceAccount.json   (gitignored)
#   - For Railway / production:
#       FIREBASE_SERVICE_ACCOUNT_B64=<base64 of serviceAccount.json>
FIREBASE_SERVICE_ACCOUNT_B64=

# Logging
LOG_LEVEL=info


# ---------- Web (apps/web/.env) ----------
# Public Firebase Web SDK config (Console -> Project settings -> Your apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=team-task-management-system.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=team-task-management-system
VITE_FIREBASE_STORAGE_BUCKET=team-task-management-system.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Where the React app should call the API
VITE_API_BASE_URL=http://localhost:4000/api
